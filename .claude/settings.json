{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(**/*.rs)|Write(**/*.rs)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/cargo-check.sh",
            "timeout": 60,
            "statusMessage": "Running cargo check..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/cargo-clippy.sh",
            "timeout": 120,
            "statusMessage": "Running clippy before finishing..."
          }
        ]
      }
    ]
  }
}
